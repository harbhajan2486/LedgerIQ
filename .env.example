# ============================================================
# LedgerIQ — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to Git.
# ============================================================

# Supabase — get these from your Supabase project dashboard
# Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — BACKEND ONLY, never expose to browser
# Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Claude API — get from console.anthropic.com
# Used by Supabase Edge Functions only — never in frontend
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# App URL — your Vercel deployment URL (or localhost for dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI cost hard limit in USD per month
AI_MONTHLY_BUDGET_USD=50
